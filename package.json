{
  "name": "sora2-video-saas",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:push": "supabase db push",
    "db:diff": "supabase db diff --linked",
    "db:reset": "supabase db reset --linked",
    "db:seed": "node scripts/db-exec.mjs supabase/seed.sql",
    "db:types": "supabase gen types typescript --linked > src/lib/supabase/types.generated.ts",
    "worker": "NODE_OPTIONS='--conditions=react-server' tsx --env-file=.env.local scripts/worker.ts",
    "bench:phase1": "NODE_OPTIONS='--conditions=react-server' tsx --env-file=.env.local scripts/benchmark-providers.ts phase1",
    "bench:phase2": "NODE_OPTIONS='--conditions=react-server' tsx --env-file=.env.local scripts/benchmark-providers.ts phase2",
    "campaign:bootstrap": "NODE_OPTIONS='--conditions=react-server' tsx --env-file=.env.local scripts/campaign-bootstrap-assets.ts",
    "campaign:upload": "NODE_OPTIONS='--conditions=react-server' tsx --env-file=.env.local scripts/campaign-upload-assets.ts",
    "campaign:worker": "NODE_OPTIONS='--conditions=react-server' tsx --env-file=.env.local scripts/campaign-worker.ts",
    "campaign:compose": "NODE_OPTIONS='--conditions=react-server' tsx --env-file=.env.local -e \"import('./src/lib/campaign/compositor/compose.ts').then(m=>m.composeAll())\"",
    "campaign:all": "NODE_OPTIONS='--conditions=react-server' tsx --env-file=.env.local scripts/campaign-run-all.ts"
  },
  "dependencies": {
    "@runwayml/sdk": "^3.20.0",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.103.0",
    "@tosspayments/tosspayments-sdk": "^2.6.0",
    "bullmq": "^5.74.1",
    "class-variance-authority": "^0.7.1",
    "cloudinary": "^2.9.0",
    "clsx": "^2.1.1",
    "ffmpeg-static": "^5.3.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^1.8.0",
    "lumaai": "^1.19.1",
    "next": "16.2.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "server-only": "^0.0.1",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "pg": "^8.20.0",
    "supabase": "^2.91.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
